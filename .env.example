# ── Stripe (live checkout — Path A) ─────────────────────────────────
# Get these from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY=sk_test_...   # use test key during development

# ── Shopify Storefront API (Path B — alternative to Stripe) ──────────
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_TOKEN=

# ── Site ─────────────────────────────────────────────────────────────
# Required for sitemap, OG images, and Stripe redirect URLs
NEXT_PUBLIC_SITE_URL=https://lamora-mu.vercel.app
